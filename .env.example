# Copy to .env (project root) and fill in real values. Never commit .env.

ENVIRONMENT=development

# Postgres (relational data only - no vector extension) - see docs/05-data-model.md
DATABASE_URL=postgresql+asyncpg://sift:sift@localhost:5432/sift

# Qdrant (vector store, one collection per Organization) - see docs/05-data-model.md and docs/07-technical-stack.md
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=

# Redis (Celery broker/backend) - see docs/07-technical-stack.md
REDIS_URL=redis://localhost:6379/0

# Object storage (S3-compatible) - see docs/06-architecture.md multi-tenancy section
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=sift-resumes-dev

# Auth provider (Auth0/Clerk) - HR user sessions, org_id claim feeds RLS session var
AUTH_JWKS_URL=
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=

# Candidate-side magic-link auth (no password, per docs/02-assumptions.md A9)
MAGIC_LINK_SECRET_KEY=
MAGIC_LINK_TTL_SECONDS=900

# AI providers - see docs/07-technical-stack.md multi-model crew assignment
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Email delivery (transactional)
EMAIL_PROVIDER_API_KEY=

# Jira (project/story sync from EPIC.md) - not part of the runtime app,
# used by local scripts/tooling only. Generate a token at
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
